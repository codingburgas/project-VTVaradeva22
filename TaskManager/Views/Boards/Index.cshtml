@model IEnumerable<TaskManager.Models.Entities.Board>
@{
    ViewData["Title"] = "Boards";
}

<h2>Boards</h2>
<a class="btn btn-primary mb-2" href="@Url.Action("Create")">Create New Board</a>

<table class="table table-striped">
    <thead>
    <tr>
        <th>Name</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var board in Model)
    {
        <tr>
            <td>@board.Name</td>
            <td>
                <a class="btn btn-sm btn-warning" href="@Url.Action("Edit", new { id = board.Id })">Edit</a>
                <a class="btn btn-sm btn-danger" href="@Url.Action("Delete", new { id = board.Id })">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>

